# Copy to .env and adjust, or export these variables directly.
# Everything is optional except ANVAYA_WORKSPACE.

# host:port the HTTP server binds (localhost only by default).
ANVAYA_BIND=127.0.0.1:7878

# ';'-separated list of workspace roots the daemon is allowed to touch.
# At least one root is required.
ANVAYA_WORKSPACE=$HOME/Desktop

# Set to 1/true to approve every request WITHOUT prompting.
# WARNING: intended for local development only.
ANVAYA_AUTO_APPROVE=0

# Max request body size in bytes (default 16 MiB).
ANVAYA_BODY_LIMIT=16777216

# ';'-separated CORS allow-list (e.g. chrome-extension://<id>).
ANVAYA_ALLOWED_ORIGINS=