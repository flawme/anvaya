{
  "name": "anvaya-extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Anvaya browser extension: routes filesystem requests to the Anvaya Rust daemon with user approval.",
  "license": "MIT OR Apache-2.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && vite build --config vite.content.config.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/chrome": "^0.0.287",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
